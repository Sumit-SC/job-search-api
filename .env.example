# ── Job Search API — Environment Variables ──
# Copy to .env and fill in values before running locally.

# Data directory for file-based job storage (default: data)
JOBS_SCRAPER_DATA_DIR=data

# Secret for /monitor endpoint (leave empty to disable auth)
MONITOR_SECRET=

# Enable Playwright headless scrapers (LinkedIn, Indeed, Naukri, etc.)
# Set to "1" to enable, "0" to disable (default: "1" but requires playwright installed)
ENABLE_HEADLESS=0

# Enable python-jobspy backend (LinkedIn, Indeed, Glassdoor, ZipRecruiter via jobspy)
# Set to "1" to enable, "0" to disable (default: "0")
USE_JOBSPY=0

# Port (Railway sets this automatically)
PORT=8000

# Proxy rotation for scraping (comma-separated, format: http://user:pass@host:port)
# Helps bypass rate-limits on hiring.cafe, wellfound, indeed, etc.
# Leave empty to scrape without proxies.
JOB_PROXY_URLS=

# ── Railway (set automatically by Railway) ──
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=job-search-api
